---
import '../styles/global.css'
import Header from '../components/Header.astro'
import NavLink from '../components/link/NavLink.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE } from '../constants'

interface Props {
  /* Should pass `null` on the home page only. */
  title: string | null
}

let { title } = Astro.props
if (title === null) {
  title = SITE_TITLE
} else {
  title = `${title} | ${SITE_TITLE}`
}
---

<!DOCTYPE html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/estrella-unitat.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div>
      <Header />
      <nav class="layout-center">
        <NavLink href="/">Inici</NavLink>
        <NavLink href="/llista">Llista</NavLink>
        <NavLink href="/blog">Blog</NavLink>
      </nav>
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
